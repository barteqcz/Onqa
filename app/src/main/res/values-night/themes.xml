<resources>
    <style name="Theme.Onqa" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">#0F0E13</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Onqa.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0E13</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Onqa</item>
    </style>
</resources>
